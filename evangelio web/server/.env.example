PORT=4000

# Opción A — Mongo sin auth local (servicio instalado en Windows o tras `docker compose up -d`):

MONGODB_URI=mongodb://127.0.0.1:27017/

#

# Opción B — Solo si tu Mongo lleva usuario y contraseña (ajusta valores reales):

# MONGODB_URI=mongodb://root:TU_CLAVE@127.0.0.1:27017/?authSource=admin



MONGODB_DB=evangelios

JWT_SECRET=definir-secreto-largo-y-aleatorio

JWT_EXPIRE=8h

# Registro móvil (código por correo).
# En Render free SMTP de Gmail suele estar bloqueado → usa BREVO_API_KEY (recomendado).
GMAIL_USER=tamponievangelio@gmail.com
MAIL_FROM=tamponievangelio@gmail.com
# GMAIL_APP_PASSWORD=16_caracteres_sin_espacios
# BREVO_API_KEY=xkeysib-...
# RESEND_API_KEY=re_...

# Evangelio: precarga en MongoDB (hoy + 30 días desde dominicos.org)
# EVANGELIO_PRECACHE_DIAS=30
# EVANGELIO_PRECACHE_AL_INICIO=1
# EVANGELIO_PRECACHE_DELAY_MS=800
# EVANGELIO_PRECACHE_REFLEXIONES=1
# EVANGELIO_PRECACHE_DELAY_OPENAI_MS=2500

# Reflexiones/preguntas (OpenAI). Sin clave → textos de respaldo en servidor.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# --- Envío diario del evangelio por email ---
# ENVIO_EMAIL_ACTIVO=1
# TZ_ENVIO=America/Santiago
# ENVIO_HORA_DEFAULT=07:00
# ENVIO_INTERVALO_MS=60000
# ENVIO_PAUSA_MS=400

# --- Producción (Render / Railway / VPS) ---
# MONGODB_URI=mongodb+srv://USUARIO:CLAVE@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# En Atlas → Network Access: permitir 0.0.0.0/0 (o la IP del servidor en la nube).
# JWT_SECRET=genera-un-secreto-largo-unico-para-produccion
# EVANGELIO_PRECACHE_AL_INICIO=0
# Panel admin: https://TU-SERVICIO.onrender.com/  (mismo servicio que la API)
# La app móvil release: --dart-define=EVANGELIO_API_BASE=https://TU-SERVICIO.onrender.com/api

